# Frontend environment variables (Vite)
# -----------------------------------
# Copy this file to `.env.local` for local development.
# In Vercel: Project Settings -> Environment Variables, add the same keys for
# Production + Preview (and Development if you use Vercel dev).
#
# IMPORTANT SECURITY NOTE
# - NEVER put Supabase `service_role` / `sb_secret_*` keys in the frontend.
# - Only use the Supabase anon/public key in the browser.

# Supabase project URL (format: https://<project-ref>.supabase.co)
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Supabase anon/public key (JWT string that starts with `eyJ...`)
# (This is safe to use client-side; do NOT use secret keys here.)
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Optional: Storage bucket used for Vault documents.
# Defaults to `vault-documents` if omitted.
VITE_SUPABASE_BUCKET="vault-documents"
